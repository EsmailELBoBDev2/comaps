# CairoDrive provider API keys -- TEMPLATE.
#
# Copy this file to `android/secrets.properties` and fill in real values.
# `secrets.properties` is gitignored and must NEVER be committed.
#
# Any key left blank or missing builds fine -- the corresponding online
# feature simply stays disabled and the app falls back to offline behaviour.
#
# Overpass (OSM camera source) needs no key and is intentionally absent here.

MAGIC_LANE=
TOMTOM=
MAPBOX=
GOOGLE_PLACES=
HERE=
GEOAPIFY=
LOCATIONIQ=
# Mapillary client access token (the "MLY|appid|token" value) - street imagery + sign detections
MAPILLARY=
# OpenRouteService (account.heigit.org) API key - routing + geocoding + isochrones
OPENROUTESERVICE=
# Optional supplementary speed-camera dataset: a URL to a GeoJSON FeatureCollection
# of Point features (props: camera_type fixed|red_light|average|mobile, maxspeed, name).
# Merged with + deduped against Overpass; leave blank to use OSM only.
CAMERA_DATASET_URL=
